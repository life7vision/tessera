# Tessera ortam değişkenleri
# Bu dosyayı .env olarak kopyala ve kendi değerlerini gir

# Kaggle API (kaggle.com -> Account -> API -> Create New Token)
KAGGLE_KEY=your_username:your_api_key

# HuggingFace Token (huggingface.co -> Settings -> Access Tokens)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Token (opsiyonel - public repo'lar için gerekmez)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Config override (opsiyonel)
# TESSERA_CONFIG=./config/production.yaml
# TESSERA_STORAGE__BASE_PATH=/mnt/data/archive
# TESSERA_PROCESSING__COMPRESSION=gzip
# TESSERA_LOGGING__LEVEL=DEBUG

